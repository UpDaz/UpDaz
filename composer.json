{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "laravel-notification-channels/discord": "^1.8",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.2",
        "laravel/tinker": "^3.0",
        "marvinlabs/laravel-discord-logger": "^1.4",
        "paragonie/sodium_compat": "^2.5",
        "prism-php/prism": "^0.100.1",
        "spatie/laravel-responsecache": "^8.0",
        "spatie/laravel-sitemap": "^8.0",
        "team-reflex/discord-php": "^10.51"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "filament/upgrade": "^5.0",
        "laravel/boost": "^2.2",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "files": [
            "app/Helpers/logs.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "update-guidelines": "curl -o ./laravel-php-guidelines.md https://spatie.be/laravel-php-ai-guidelines.md"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
